# AUTOMATICA Agent Runtime — Central Configuration
# Copy to ~/.automatica.env and fill in your API keys.
# This file is read by arun CLI to configure container runs.

# ── Workspace ──
# Directory to mount into the container. Agent works inside this dir.
AUTOMATICA_WORKSPACE=/Users/you/src

# Mount mode: snapshot (copy, safe) or bind (live sync)
AUTOMATICA_MODE=snapshot

# ── Active Provider ──
# Which provider to use by default: zai | minimax
AUTOMATICA_PROVIDER=zai

# ── Z.AI ──
ZAI_API_KEY=your-zai-api-key
ZAI_BASE_URL=https://api.z.ai/api/anthropic
ZAI_MODEL=glm-4.7
ZAI_HAIKU_MODEL=GLM-4.5-Air

# ── MiniMax ──
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# ── Container Settings ──
API_TIMEOUT_MS=3000000
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
